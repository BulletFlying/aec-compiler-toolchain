# CAS succeeds on even lanes and returns the old value on every independent cell.
CPY.u32 R1, %laneid
LOADI R2, 2
SHL.u32 R3, R1, R2
LOADI R4, 1
AND.u32 R5, R1, R4
LOADI R6, 0
CMPP.eq.u32 P1, R5, R6
LOADI R7, 0xaaaa0000
LOADI R8, 0xbbbb0000
@P1 ATOM.gmem.cas.u32 R9, [R3], R7, R8
LOADI R10, 0x100
ADD.u32 R11, R10, R3
ST.gmem.u32 [R11], R9
HALT
